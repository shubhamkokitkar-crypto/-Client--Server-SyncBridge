<Window x:Class="TCPClientWPF1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCP Client" Height="500" Width="750">
    <Grid Margin="10">
        <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <!-- ✅ ADD THIS -->
    </Grid.RowDefinitions>

    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

            <Label Content="Server IP:" VerticalAlignment="Center"/>

            <ComboBox x:Name="cmbIP"
              Width="150"
              Margin="5,0"
              IsEditable="True"/>

            <Label Content="Port:" Margin="5,0,0,0" VerticalAlignment="Center"/>

            <ComboBox x:Name="cmbPort"
              Width="90"
              IsEditable="True"
              Margin="5,0">
                <ComboBoxItem Content="5000"/>
                <ComboBoxItem Content="6000"/>
                <ComboBoxItem Content="7000"/>
            </ComboBox>

            <Button x:Name="btnConnect"
            Content="Connect"
            Width="80"
            Margin="5,0"
            Click="btnConnect_Click"/>

            <Button Content="Open Log"
            Width="80"
            Margin="5,0"
            Click="btnOpenLog_Click"/>

            <Button Content="Clear Log"
            Width="80"
            Margin="5,0"
            Click="btnClearLog_Click"/>

        </StackPanel>

        <TextBox x:Name="txtChat"
                 Grid.Row="1"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 IsReadOnly="True"/>
        <!-- Bottom Panel -->
        <Grid Grid.Row="2" Grid.RowSpan="2" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- First Line : Message + Send -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtMessage"
                 Grid.Column="0"
                 Height="25"
                 Margin="0,0,10,0"/>

                <Button Content="Send"
                Grid.Column="1"
                Height="25"
                Click="btnSend_Click"/>
            </Grid>

            <!-- Second Line : All controls in one line -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="cmbDataFiles"
                  Grid.Column="0"
                  Height="25"
                  Margin="0,0,5,0"/>

                <Button Content="Fetch CSV"
                Grid.Column="1"
                Height="25"
                Margin="0,0,5,0"
                Click="btnFetchCsv_Click"/>

                <Button x:Name="btnRefresh"
                Grid.Column="2"
                Content="Refresh"
                Height="25"
                Margin="0,0,5,0"
                Click="btnRefresh_Click"/>

                <Button Name="btnClearTable"
                Grid.Column="3"
                Content="Clear Table"
                Height="25"
                Margin="0,0,5,0"
                Click="btnClearTable_Click"/>

                <ComboBox x:Name="cmbTables"
                  Grid.Column="4"
                  Height="25"
                  Margin="0,0,5,0"/>

                <Button Content="Fetch SQL Table"
                Grid.Column="5"
                Height="25"
                Click="btnFetchTable_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
